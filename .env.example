# ===========================================
# 符寶網 环境变量配置
# ===========================================

# ===========================================
# API 配置
# ===========================================

# API 模式: local = 使用 Next.js API Routes, remote = 使用远程 PHP 后端
NEXT_PUBLIC_API_MODE=local

# 远程 PHP API 地址（当 API_MODE=remote 时使用）
NEXT_PUBLIC_API_URL=https://api.fubao.com

# ===========================================
# Supabase 配置（本地模式使用）
# ===========================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# PHP 后端配置（远程模式使用）
# ===========================================

# PHP 后端数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fubao
DB_USER=root
DB_PASSWORD=your_password

# JWT 密钥
JWT_SECRET=your-production-secret-key-here

# ===========================================
# AI 配置
# ===========================================

# Coze API Token（用于新闻搜索）
COZE_API_TOKEN=your-coze-api-token

# AI 模型配置
# 支持: doubao, deepseek, kimi, glm, qwen
AI_PROVIDER=doubao
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ===========================================
# 对象存储配置
# ===========================================

# S3 兼容存储
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=fubao
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ===========================================
# 第三方服务
# ===========================================

# 短信服务（阿里云等）
SMS_ACCESS_KEY=your-access-key
SMS_ACCESS_SECRET=your-access-secret
SMS_SIGN_NAME=符寶網

# 邮件服务
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=no-reply@fubao.com

# ===========================================
# OAuth 配置
# ===========================================

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# 微信 OAuth
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Twitter/X OAuth
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
