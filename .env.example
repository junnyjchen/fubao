# =============================================
# 符寶網 环境变量配置
# =============================================

# 应用环境
NODE_ENV=development
COZE_PROJECT_ENV=DEV

# 数据库配置 (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=fubao

# Supabase 配置（保留，向后兼容）
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=

# JWT 密钥
JWT_SECRET=fubao-ltd-jwt-secret-key-2024

# 对象存储 (可选)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=

# 第三方服务 (可选)
# COZE_API_TOKEN=
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
